{
  "manifest_version": 3,
  "name": "WatchTogether",
  "version": "0.1.0",
  "description": "Watch videos in sync with a friend",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "*://anime1.me/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://anime1.me/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
